Question 33
Write a program to Print reverse star pattern.
*****
****
***
**
*

# Program to print reverse star pattern

n = int(input("Enter number of rows: "))

for i in range(n, 0, -1):
    print("*" * i)

Question 34
Write a program to Print reverse number triangle.
12345
1234
123
12
1

# Program to print reverse number triangle

n = int(input("Enter number of rows: "))

for i in range(n, 0, -1):
    for j in range(1, i + 1):
        print(j, end="")
    print()

Question 35
Write a program to Print repeated character pattern.
A
BB
CCC
DDDD
EEEEE

# Program to print repeated character pattern

n = int(input("Enter number of rows: "))

for i in range(1, n + 1):
    ch = chr(64 + i)
    print(ch * i)

Question 36
Write a program to Print hollow square pattern.
*****
*  *
*   *
*   *
*****

# Program to print hollow square pattern

n = int(input("Enter size of square: "))

for i in range(n):
    for j in range(n):
        if i == 0 or i == n - 1 or j == 0 or j == n - 1:
            print("*", end="")
        else:
            print(" ", end="")
    print()
