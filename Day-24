Question 93
Write a program to Check string rotation.

#include <stdio.h>
#include <string.h>

int main() {
    char str1[100], str2[100], temp[200];

    printf("Enter first string: ");
    scanf("%s", str1);

    printf("Enter second string: ");
    scanf("%s", str2);

    if(strlen(str1) != strlen(str2)) {
        printf("Strings are not rotations.");
        return 0;
    }

    strcpy(temp, str1);
    strcat(temp, str1);

    if(strstr(temp, str2))
        printf("Strings are rotations.");
    else
        printf("Strings are not rotations.");

    return 0;
}
Question 94
Write a program to Compress a string.

#include <stdio.h>

int main() {
    char str[100];
    int i, count;

    printf("Enter a string: ");
    scanf("%s", str);

    printf("Compressed string: ");

    for(i = 0; str[i] != '\0'; i++) {
        count = 1;

        while(str[i] == str[i + 1]) {
            count++;
            i++;
        }

        printf("%c%d", str[i], count);
    }

    return 0;
}

Question 95
Write a program to Find longest word.

#include <stdio.h>
#include <string.h>

int main() {
    char str[200], longest[100], word[100];
    int i = 0, j = 0, max = 0;

    printf("Enter a sentence: ");
    fgets(str, sizeof(str), stdin);

    while (1) {
        if (str[i] != ' ' && str[i] != '\0' && str[i] != '\n') {
            word[j++] = str[i];
        } else {
            word[j] = '\0';

            if (j > max) {
                max = j;
                strcpy(longest, word);
            }

            j = 0;

            if (str[i] == '\0' || str[i] == '\n')
                break;
        }
        i++;
    }

    printf("Longest word: %s\n", longest);
    printf("Length: %d\n", max);

    return 0;
}

Question 96
Write a program to Remove duplicate characters.

#include <stdio.h>

int main() {
    char str[100];
    int i, j, k;

    printf("Enter a string: ");
    scanf("%s", str);

    for(i = 0; str[i] != '\0'; i++) {
        for(j = i + 1; str[j] != '\0'; j++) {
            if(str[i] == str[j]) {
                for(k = j; str[k] != '\0'; k++) {
                    str[k] = str[k + 1];
                }
                j--;
            }
        }
    }

    printf("String after removing duplicate characters: %s\n", str);

    return 0;
}
