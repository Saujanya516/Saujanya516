Question 53
Write a program to Linear search.

# Program to perform linear search

n = int(input("Enter number of elements: "))
arr = list(map(int, input("Enter elements separated by space: ").split()))

target = int(input("Enter number to search: "))

position = -1
for i in range(n):
    if arr[i] == target:
        position = i
        break

if position != -1:
    print(f"{target} found at index {position} (position {position + 1})")
else:
    print(f"{target} not found in the array")

Question 54
Write a program to Frequency of an element.

# Program to find frequency of an element in array

n = int(input("Enter number of elements: "))
arr = list(map(int, input("Enter elements separated by space: ").split()))

target = int(input("Enter number to find frequency of: "))

count = 0
for element in arr:
    if element == target:
        count += 1

print(f"\nArray elements: {arr}")
print(f"Frequency of {target} = {count}")

Question 55
Write a program to Second largest element.

# Program to find second largest element in array

n = int(input("Enter number of elements: "))
arr = list(map(int, input("Enter elements separated by space: ").split()))

largest = second_largest = float('-inf')

for element in arr:
    if element > largest:
        second_largest = largest
        largest = element
    elif element > second_largest and element != largest:
        second_largest = element

if second_largest == float('-inf'):
    print("No second largest element (all elements may be equal or array too small)")
else:
    print(f"\nArray elements: {arr}")
    print(f"Largest element = {largest}")
    print(f"Second largest element = {second_largest}")

Question 56
Write a program to Find duplicates in array.
# Program to find duplicates in array

n = int(input("Enter number of elements: "))
arr = list(map(int, input("Enter elements separated by space: ").split()))

seen = set()
duplicates = set()

for element in arr:
    if element in seen:
        duplicates.add(element)
    else:
        seen.add(element)

print(f"\nArray elements: {arr}")
if duplicates:
    print(f"Duplicate elements = {sorted(duplicates)}")
else:
    print("No duplicate elements found")
